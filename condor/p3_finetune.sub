# p3_finetune.sub — GPU job: PIPELINE 3 (fine-tune the released checkpoint).
# run_finetune.sh continues training the authors' karmadock_screening.pkl on proto_train
# (single stage, pos_r=1, lr 1e-4, wd 0, patience 30). Checkpoints + --resume => safe.
#
# args: <train_csv> <graph_dir> <complex_dir> <out_dir> [batch_size] [accum_steps]
#   condor_submit p3_finetune.sub

universe      = docker
docker_image  = ahlamloum/karmadock-seminar:v6
+WantGPUHomeMounted = true
requirements = UidDomain == "cs.uni-saarland.de" && (Machine =!= "idun.hpc.uni-saarland.de")

executable = /home/bdldt_team002/run/code/scripts/run_finetune.sh
arguments  = /home/bdldt_team002/run/data/proto/proto_train.csv /home/bdldt_team002/run/work/graphs/proto_train /home/bdldt_team002/run/work/complex/proto_train /home/bdldt_team002/run/work/ckpt/p3_finetune 4 16

should_transfer_files = NO

output = /home/bdldt_team002/run/logs/p3_finetune.$(ClusterId).$(ProcId).out
error  = /home/bdldt_team002/run/logs/p3_finetune.$(ClusterId).$(ProcId).err
log    = /home/bdldt_team002/run/logs/p3_finetune.$(ClusterId).log

request_gpus   = 1
request_cpus   = 8
request_memory = 48GB

queue 1
